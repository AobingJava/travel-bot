APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-another-random-secret

# OpenAI-compatible LLM endpoint
LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
LLM_API_KEY=replace-with-a-rotated-key
LLM_MODEL=glm-4.5-air

# SMTP mail delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Wander <no-reply@example.com>

# Cloudflare D1 direct REST access
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_D1_API_TOKEN=

# Optional D1 proxy Worker instead of direct REST
D1_PROXY_URL=
D1_PROXY_TOKEN=

# Amap (高德地图) JS API Key
NEXT_PUBLIC_AMAP_KEY=
NEXT_PUBLIC_AMAP_SECURITY_CODE=
